msgid "Teleprompter"
msgstr "Teleprompter"

#: data/io.github.nokse22.teleprompter.appdata.xml.in:8
msgid ""
"A simple app to read scrolling text from your screen. It has an adaptive "
"layout to work on smartphones too."
msgstr ""
"Jednostavna aplikacija za čitanje kliznog teksta s tvog ekrana. Ima "
"prilagodljiv izgled kako bi radila i na mobitelima."

#: data/io.github.nokse22.teleprompter.appdata.xml.in:11
msgid "Stay on track during speeches"
msgstr "Nemoj izbubiti tijek govora"

#: data/io.github.nokse22.teleprompter.appdata.xml.in:146
msgid "Teleprompter displaying text on a widescreen"
msgstr "Teleprompter prikazuje tekst na širokom ekranu"

#: data/io.github.nokse22.teleprompter.appdata.xml.in:151
msgid "Teleprompter displaying text on a widescreen with dark theme"
msgstr "Teleprompter prikazuje tekst na širokom ekranu s tamnom temom"

#: data/io.github.nokse22.teleprompter.appdata.xml.in:156
msgid "Teleprompter displaying text in a narrow screen"
msgstr "Teleprompter prikazuje tekst na uskom ekranu"

