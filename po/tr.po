#: data/io.github.nokse22.teleprompter.appdata.xml.in:8
msgid ""
"A simple app to read scrolling text from your screen. It has an adaptive "
"layout to work on smartphones too."
msgstr ""
"Ekranınızdan kayan metni okumak için basit bir uygulama. Akıllı telefonlarda "
"da çalışmak için uyarlanabilir düzene sahiptir."

#: data/io.github.nokse22.teleprompter.appdata.xml.in:11
msgid "Stay on track during speeches"
msgstr "Konuşma sırasında dikkatiniz dağılmasın"

#: data/io.github.nokse22.teleprompter.appdata.xml.in:147
msgid "Teleprompter displaying text on a widescreen"
msgstr "Teleprompter, geniş ekranda metin görüntülerken"

#: data/io.github.nokse22.teleprompter.appdata.xml.in:152
msgid "Teleprompter displaying text on a widescreen with dark theme"
msgstr "Teleprompter, koyu temalı geniş ekranda metin görüntülerken"

#: data/io.github.nokse22.teleprompter.appdata.xml.in:157
msgid "Teleprompter displaying text in a narrow screen"
msgstr "Teleprompter, dar ekranda metin görüntülerken"

